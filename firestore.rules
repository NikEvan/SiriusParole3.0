rules_version = '2';

// Regole Firestore — Sirius Parole 3.0
// Da incollare in Firebase Console > Firestore Database > Rules

service cloud.firestore {
  match /databases/{database}/documents {

    // Classifica giornaliera
    match /leaderboards/{dayOffset}/scores/{codice} {
      allow read: if true;
      allow create: if request.auth != null
        && request.resource.data.attempts is int
        && request.resource.data.attempts >= 1
        && request.resource.data.attempts <= 7
        && request.resource.data.status in ['win', 'lose']
        && request.resource.data.name is string
        && request.resource.data.name.size() <= 50;
      allow update, delete: if false;
    }

    // Classifica mensile aggregata
    match /monthly/{monthKey}/players/{codice} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.resource.data.totalAttempts is int
        && request.resource.data.totalAttempts >= 0
        && request.resource.data.totalAttempts < 100000;
      allow delete: if false;
    }

    // Snapshot posizioni (frecce)
    match /snapshots/{snapId} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // Albo d'oro
    match /winners/{monthKey} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // AMMONIZIONI — nuova collection
    match /warnings/{dayOffset}/received/{codice} {
      allow read: if true;
      // Consentiamo create/update (serve per aggiungere/ritirare in transazione)
      // La logica anti-abuso (una volta per persona, ritiro solo sotto soglia) è nel client + transazione.
      allow create, update: if request.auth != null
        && request.resource.data.count is int
        && request.resource.data.count >= 0
        && request.resource.data.count <= 60;
      allow delete: if false;
    }
  }
}
